# =============================================================================
# .gitignore — notes-to-icd10
# =============================================================================
# Principle: track source code, configuration, notebooks, and documentation.
# Exclude everything that is large, generated, reproducible, or sensitive.
# =============================================================================


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Type checking
.mypy_cache/
.dmypy.json
.pytype/
.pyre/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/


# -----------------------------------------------------------------------------
# Virtual environments
# Package managers: uv, pip, conda
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# uv lock file — reproducibility is handled by pyproject.toml + uv sync.
# Committing uv.lock is valid for applications; for a research project where
# deps evolve rapidly, omitting it keeps diffs cleaner. Revisit if you want
# fully pinned reproducible installs for collaborators.
uv.lock

# Conda
*.conda/
*.env


# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/


# -----------------------------------------------------------------------------
# Model weights and checkpoints
# These are large binary files — store in HuggingFace Hub, S3, or similar.
# The registry metadata (JSON files) IS tracked — see outputs/ section below.
# -----------------------------------------------------------------------------

# HuggingFace local model cache
.hf_cache/
data/cache/

# Trained model weights (safetensors, PyTorch binaries)
*.safetensors
*.bin
*.pt
*.ckpt

# Transformer checkpoint directories (produced by HuggingFace Trainer)
# Matches both standard names (checkpoints/) and variant names (checkpoints_e005a/)
**/checkpoints/
**/checkpoints_*/
**/best_model/
**/final/

# PyTorch random state files
*.pth

# Stage-2 resolver model subdirectories (binary weights only — JSON is tracked)
# Pattern: outputs/evaluations/{exp}/stage2/{chapter}/model/
# The label_map.json inside is tracked (see outputs/ rules); the weights are not.
outputs/evaluations/*/stage2/*/model/*.safetensors
outputs/evaluations/*/stage2/*/model/*.bin
outputs/evaluations/*/stage2/*/model/*.pt

# Registry model weights (JSON metadata IS tracked — see below)
outputs/evaluations/registry/*/model/*.safetensors
outputs/evaluations/registry/*/model/*.bin
outputs/evaluations/registry/*/model/*.pt


# -----------------------------------------------------------------------------
# Data files
# Raw and processed data are large and reproducible from source.
# The Gold layer Parquet can be regenerated by running notebook 01 / prepare_data.py.
# -----------------------------------------------------------------------------
data/raw/
data/silver/
data/gold/
data/cache/

# Do NOT exclude data/ entirely — keeps the directory structure in git
# via the .gitkeep files added below.


# -----------------------------------------------------------------------------
# Experiment tracking
# -----------------------------------------------------------------------------

# MLflow SQLite database and run artifacts
mlflow.db
mlruns/

# TensorBoard event files (top-level logs/ and nested inside outputs/)
logs/
*.tfevents.*
outputs/evaluations/*/stage2/tensorboard/
outputs/evaluations/*/stage1/tensorboard/

# DuckDB audit trail database (large, binary, regenerable)
db/
*.ddb
*.duckdb


# -----------------------------------------------------------------------------
# Outputs — selective exclusion
#
# We TRACK:   label mappings, final metrics, e2e results (small JSON)
# We EXCLUDE: model weights (above), Parquet eval artifacts, visualisations,
#             raw prediction files
# -----------------------------------------------------------------------------
outputs/predictions/
outputs/visualizations/
outputs/reports/

# Per-experiment large artifacts (training curves, confusion matrix PNGs etc.)
# Note: git doesn't support ** globbing — use explicit depth patterns instead
outputs/evaluations/*/*.png
outputs/evaluations/*/*.jpg
outputs/evaluations/*/*/*.png
outputs/evaluations/*/*/*.jpg
outputs/evaluations/registry/*/*.png
outputs/evaluations/registry/*/*.jpg
outputs/evaluations/registry/*/stage1/*.png

# training_args.bin — binary, not needed in git (caught by *.bin above,
# but listed explicitly for clarity since it appears in many subdirectories)
training_args.bin

# Processing log (append-only JSONL, grows unboundedly — regenerable)
outputs/evaluations/processing_log.jsonl

# TRACK these (small, essential for inference and reproducibility):
# outputs/evaluations/registry/*/label_mapping.json
# outputs/evaluations/registry/*/final_metrics.json
# outputs/evaluations/registry/*/experiment_config.json
# outputs/evaluations/registry/*/e2e_results.json
# outputs/evaluations/*/stage2/*/model/label_map.json
# outputs/evaluations/*/stage2/stage2_results.json
# (No exclude rules needed for these — they are not matched by patterns above)


# -----------------------------------------------------------------------------
# Jupyter notebooks — output stripping
#
# Notebook SOURCES are tracked. Cell outputs (which embed base64 images,
# dataframes, and training logs) are excluded via nbstripout.
#
# nbstripout is configured as a git filter (see setup instructions in README).
# This means outputs are stripped automatically on git add — you never need
# to manually clear them.
#
# To set up: uv run nbstripout --install
# -----------------------------------------------------------------------------
# Raw .ipynb files with outputs are NOT excluded here — nbstripout handles it.
# If you haven't installed nbstripout yet, uncomment the line below as a
# fallback (but prefer nbstripout for a cleaner workflow):
# *.ipynb


# -----------------------------------------------------------------------------
# Backup files created during refactoring
# -----------------------------------------------------------------------------
*.bak
*.orig
*.tmp


# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.spyderproject.cfg
.ropeproject/
*.sublime-workspace

# JupyterLab
.jupyter/
.ipynb_checkpoints/


# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.log
*.pidoutputs/
gold.jsonl
project_handoff.zip

# Local Claude setup
Claude_Code_Local_Setup_Guide_v2.md
start-claude-local-v2.sh

# Large outputs
outputs/
graphify-out/
data/graph/
*.zip

# Notebook backups
notebooks/OLD_*.ipynb
notebooks/*\ 1.ipynb

